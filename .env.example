# KitchenLuxe environment variables

# Site configuration
NEXT_PUBLIC_BASE_URL=https://kitchenluxe.vercel.app
NEXT_PUBLIC_SITE_URL=https://kitchenluxe.vercel.app

# Amazon Associates
NEXT_PUBLIC_AMAZON_TAG_FR=kitchenluxe-21
NEXT_PUBLIC_AMAZON_TAG_US=kitchenluxe-20

# Admin/API protection
# Required in production. Use /admin?key=... once to set the admin cookie.
KITCHENLUXE_API_KEY=
CRON_SECRET=

# Optional generation and automation
GEMINI_API_KEY=
AUTOPILOT_DAILY_LIMIT=3
AUTOPILOT_AUTO_PROMOTE=1
AUTOPILOT_QUALITY_MIN_SCORE=82

# Optional social webhooks. Leave blank for manual/export mode.
PINTEREST_WEBHOOK=
MAKE_WEBHOOK_URL=
PINTEREST_MIN_QUALITY_SCORE=85

# Official Pinterest API. Keep dry-run on until Neska validates real publishing.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=https://kitchenluxe.vercel.app/api/pinterest/oauth/callback
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
PINTEREST_BOARD_SECTION_ID=
PINTEREST_API_BASE_URL=https://api.pinterest.com/v5
PINTEREST_API_DRY_RUN=1
